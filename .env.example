# Example environment variables for MTC Bridge + ACME server
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# DigiCert CA database credentials (required)
MTC_CADB_HOST=ca-db
MTC_CADB_PORT=3306
MTC_CADB_USERNAME=
MTC_CADB_PASSWORD=
MTC_CADB_DATABASE=digicert_ca

# PostgreSQL state store
MTC_POSTGRES_PASSWORD=mtcbridge

# DigiCert CA API (required for proxy mode)
CA_URL=http://localhost
CA_API_KEY=
CA_ID=
CA_TEMPLATE_ID=

# Bridge HTTP port
MTC_HTTP_PORT=8080
